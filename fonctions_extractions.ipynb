    "# ==============================================================================\n",
    "# ÉTAPE 5 : PHASE DE MACHINE LEARNING (SUPERVISÉ & NON SUPERVISÉ)\n",
    "# ==============================================================================\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Outils de prétraitement et de réduction\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.decomposition import PCA\n",
    "\n",
    "# Modèles et métriques\n",
    "from sklearn.cluster import KMeans\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.metrics import classification_report, confusion_matrix, roc_curve, auc, silhouette_score\n",
    "\n",
    "# Configuration des graphiques\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "plt.rcParams['figure.figsize'] = (10, 6)\n",
    "\n",
    "# ------------------------------------------------------------------------------\n",
    "# 1. CHARGEMENT ET PRÉPARATION DES DONNÉES ENRICHIES\n",
    "# ------------------------------------------------------------------------------\n",
    "print(\"--- Chargement des données ---\")\n",
    "\n",
    "# Chargement du dataset généré lors des étapes précédentes\n",
    "df_ml = pd.read_csv('donnees_enrichies.csv')\n",
    "\n",
    "print(f\"Taille initiale du dataset : {df_ml.shape}\")\n",
    "\n",
    "# --- Sécurité : Simulation des colonnes si absentes (uniquement pour la démo) ---\n",
    "if 'cvss' not in df_ml.columns:\n",
    "    df_ml['cvss'] = np.random.choice([np.nan, 4.5, 7.2, 9.8, 5.0], size=len(df_ml))\n",
    "if 'epss' not in df_ml.columns:\n",
    "    df_ml['epss'] = np.random.choice([np.nan, 0.01, 0.45, 0.89, 0.05], size=len(df_ml))\n",
    "\n",
    "# --- MODIFICATION INTERVENUE ICI : SUPPRESSION STRICTE DES VALEURS MANQUANTES ---\n",
    "# On ne garde que les lignes qui contiennent À LA FOIS le CVSS et l'EPSS\n",
    "df_ml = df_ml.dropna(subset=['cvss', 'epss'])\n",
    "\n",
    "if 'has_anssi_alert' not in df_ml.columns:\n",
    "    df_ml['has_anssi_alert'] = np.random.choice([0, 1], size=len(df_ml), p=[0.85, 0.15])\n",
    "\n",
    "print(f\"Taille du dataset après filtre (lignes complètes uniquement) : {df_ml.shape}\")\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------------------------\n",
    "# 2. APPRENTISSAGE NON SUPERVISÉ : CLUSTERING (K-MEANS) & PCA\n",
    "# ------------------------------------------------------------------------------\n",
    "print(\"\\n--- Début de la phase Non Supervisée ---\")\n",
    "\n",
    "# Sélection des features numériques pour le clustering\n",
    "features_clustering = ['cvss', 'epss']\n",
    "X_clust = df_ml[features_clustering]\n",
    "\n",
    "# Standardisation des données (étape cruciale pour K-Means)\n",
    "scaler = StandardScaler()\n",
    "X_clust_scaled = scaler.fit_transform(X_clust)\n",
    "\n",
    "# Détermination du nombre optimal de clusters (Méthode du Coude)\n",
    "wcss = []\n",
    "for i in range(1, 7):\n",
    "    kmeans = KMeans(n_clusters=i, init='k-means++', random_state=42, n_init=10)\n",
    "    kmeans.fit(X_clust_scaled)\n",
    "    wcss.append(kmeans.inertia_)\n",
    "\n",
    "# Visualisation 1 : Méthode du coude\n",
    "plt.figure(figsize=(8, 4))\n",
    "plt.plot(range(1, 7), wcss, marker='o', linestyle='--', color='b')\n",
    "plt.title('Visualisation 1 : Méthode du Coude pour déterminer K')\n",
    "plt.xlabel('Nombre de Clusters')\n",
    "plt.ylabel('WCSS (Inertie intra-classe)')\n",
    "plt.show()\n",
    "\n",
    "# Choix de K=3 (Profils : Faible risque, Risque Modéré, Menace Critique)\n",
    "k_optimal = 3\n",
    "kmeans_final = KMeans(n_clusters=k_optimal, init='k-means++', random_state=42, n_init=10)\n",
    "df_ml['cluster'] = kmeans_final.fit_predict(X_clust_scaled)\n",
    "\n",
    "# Validation du clustering : Calcul du coefficient de Silhouette\n",
    "sil_score = silhouette_score(X_clust_scaled, df_ml['cluster'])\n",
    "print(f\"Validation du Clustering - Score de Silhouette : {sil_score:.3f}\")\n",
    "\n",
    "# Visualisation 2 : Réduction de dimension avec PCA et affichage des Clusters\n",
    "pca = PCA(n_components=2)\n",
    "X_pca = pca.fit_transform(X_clust_scaled)\n",
    "df_ml['PCA1'] = X_pca[:, 0]\n",
    "df_ml['PCA2'] = X_pca[:, 1]\n",
    "\n",
    "plt.figure(figsize=(9, 6))\n",
    "sns.scatterplot(x='PCA1', y='PCA2', hue='cluster', data=df_ml, palette='Set1', alpha=0.7)\n",
    "plt.title('Visualisation 2 : Regroupement thématique des vulnérabilités (PCA & K-Means)')\n",
    "plt.xlabel('Composante Principale 1')\n",
    "plt.ylabel('Composante Principale 2')\n",
    "plt.legend(title='Clusters de Risque')\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------------------------\n",
    "# 3. APPRENTISSAGE SUPERVISÉ : CLASSIFICATION (RANDOM FOREST)\n",
    "# ------------------------------------------------------------------------------\n",
    "print(\"\\n--- Début de la phase Supervisée ---\")\n",
    "\n",
    "# Définition de la cible (Target) : Vulnérabilité Prioritaire (CVSS >= 7.0)\n",
    "df_ml['is_priority'] = (df_ml['cvss'] >= 7.0).astype(int)\n",
    "\n",
    "# Variables explicatives (Features)\n",
    "features_supervise = ['epss', 'has_anssi_alert', 'cluster']\n",
    "X_sup = df_ml[features_supervise]\n",
    "y_sup = df_ml['is_priority']\n",
    "\n",
    "# Division en jeu d'entraînement (80%) et jeu de test (20%)\n",
    "X_train, X_test, y_train, y_test = train_test_split(X_sup, y_sup, test_size=0.2, random_state=42, stratify=y_sup)\n",
    "\n",
    "# Initialisation et entraînement du classifieur Random Forest\n",
    "rf_clf = RandomForestClassifier(n_estimators=100, random_state=42)\n",
    "rf_clf.fit(X_train, y_train)\n",
    "\n",
    "# Prédictions\n",
    "y_pred = rf_clf.predict(X_test)\n",
    "y_prob = rf_clf.predict_proba(X_test)[:, 1]\n",
    "\n",
    "# --- VALIDATION DU MODÈLE SUPERVISÉ ---\n",
    "print(\"\\nRapport de Classification :\")\n",
    "print(classification_report(y_test, y_pred))\n",
    "\n",
    "# Visualisation 3 : Matrice de Confusion\n",
    "cm = confusion_matrix(y_test, y_pred)\n",
    "plt.figure(figsize=(6, 5))\n",
    "sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', xticklabels=['Non Prioritaire', 'Prioritaire'], yticklabels=['Non Prioritaire', 'Prioritaire'])\n",
    "plt.title('Visualisation 3 : Matrice de Confusion - Random Forest')\n",
    "plt.ylabel('Réalité (True Label)')\n",
    "plt.xlabel('Prédiction (Predicted Label)')\n",
    "plt.show()\n",
    "\n",
    "# Visualisation 4 : Courbe ROC et calcul de l'AUC\n",
    "fpr, tpr, thresholds = roc_curve(y_test, y_prob)\n",
    "roc_auc = auc(fpr, tpr)\n",
    "\n",
    "plt.figure(figsize=(7, 5))\n",
    "plt.plot(fpr, tpr, color='darkorange', lw=2, label=f'Courbe ROC (AUC = {roc_auc:.2f})')\n",
    "plt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--')\n",
    "plt.xlim([0.0, 1.0])\n",
    "plt.ylim([0.0, 1.05])\n",
    "plt.title('Visualisation 4 : Courbe ROC de validation du modèle')\n",
    "plt.xlabel('Taux de Faux Positifs (FPR)')\n",
    "plt.ylabel('Taux de Vrais Positifs (TPR)')\n",
